# Data files — never commit raw Parquet/CSV
data/
*.parquet
*.csv

# DBT artifacts
dbt/target/
dbt/dbt_packages/
dbt/logs/

# Credentials
.env
*credentials*
*secrets*
profiles.yml        # use profiles.yml.example instead

# DuckDB local database
*.duckdb
*.db

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
dist/
*.egg-info/

# Airflow
airflow/logs/
airflow/plugins/
airflow.db
airflow.cfg

# IDE
.idea/
.vscode/
*.DS_Store
local_tests/

# Default .gitignore content added by dbt Cloud# you shouldn't commit these into source control
# these are the default directory names, adjust/add to fit your needs
target/
dbt_packages/
logs/
# end dbt Cloud content
dbt_internal_packages/
